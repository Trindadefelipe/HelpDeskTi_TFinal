<%- include('../partials/layout-start', { title: 'Chamados - Helpdesk TI', active: 'dashboard' }) %>

<%
    const statusBadge = { 'Aberto': 'badge-dark', 'Em Atendimento': 'badge-muted', 'Resolvido': 'badge-green', 'Cancelado': 'badge-danger' };
%>

<div class="page-header">
    <div>
        <h1 class="page-title">Chamados</h1>
        <p class="page-subtitle">Gerenciamento de Chamados de TI</p>
    </div>
    <a href="/chamados/novo" class="btn-app btn-dark-app"><i class="bi bi-plus-lg"></i> Novo Chamado</a>
</div>

<div class="panel">
    <div class="panel-head">
        <h2 class="panel-title">Lista de Chamados</h2>
        <p class="panel-subtitle"><%= chamados.length %> chamado(s) encontrado(s)</p>
    </div>

    <table class="table-app">
        <thead>
            <tr>
                <th>ID</th>
                <th>Título</th>
                <th>Solicitante</th>
                <th>Categoria</th>
                <th>Status</th>
                <th>Técnico</th>
                <th>Departamento</th>
                <th>Abertura</th>
                <th class="text-end">Ações</th>
            </tr>
        </thead>
        <tbody>
            <% if (chamados.length === 0) { %>
                <tr>
                    <td colspan="9" style="text-align: center; padding: 24px; color: #64748b;">Nenhum chamado cadastrado.</td>
                </tr>
            <% } %>
            <% chamados.forEach(c => { %>
                <tr>
                    <td class="id-cell">#<%= c.id_chamado %></td>
                    <td class="title-cell"><%= c.titulo %></td>
                    <td><%= c.solicitante %></td>
                    <td><%= c.categoria %></td>
                    <td><span class="badge-app <%= statusBadge[c.status] || 'badge-muted' %>"><%= c.status %></span></td>
                    <td><%= c.tecnico || '—' %></td>
                    <td><%= c.departamento || '—' %></td>
                    <td><%= new Date(c.data_abertura).toLocaleDateString('pt-BR') %></td>
                    <td>
                        <div class="actions-cell">
                            <a href="/chamados/editar/<%= c.id_chamado %>" class="btn-app btn-outline-app">Editar</a>
                            <form action="/chamados/excluir/<%= c.id_chamado %>" method="POST" style="display: inline;" onsubmit="return confirm('Excluir este chamado?');">
                                <button type="submit" class="btn-app btn-danger-app">Excluir</button>
                            </form>
                        </div>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<%- include('../partials/layout-end') %>
