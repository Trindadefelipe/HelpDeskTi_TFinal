<%- include('../partials/layout-start', { title: 'Editar Departamento - Helpdesk TI', active: 'departamentos' }) %>

<a href="/departamentos" class="back-link"><i class="bi bi-arrow-left"></i> Voltar</a>

<div class="page-header">
    <div>
        <h1 class="page-title">Editar Departamento</h1>
        <p class="page-subtitle">Atualize as informações do departamento</p>
    </div>
</div>

<div class="panel form-card">
    <% if (erro) { %>
        <div class="alert-app"><%= erro %></div>
    <% } %>
    <form action="/departamentos/<%= departamento.id_departamento %>" method="POST">
        <div class="field">
            <label class="label-app" for="nome">Nome <span class="req">*</span></label>
            <input class="input-app" type="text" id="nome" name="nome" value="<%= departamento.nome %>" required>
        </div>

        <div class="field">
            <label class="label-app" for="responsavel">Responsável</label>
            <input class="input-app" type="text" id="responsavel" name="responsavel" value="<%= departamento.responsavel || '' %>">
        </div>

        <div class="field">
            <label class="label-app" for="localizacao">Localização</label>
            <input class="input-app" type="text" id="localizacao" name="localizacao" value="<%= departamento.localizacao || '' %>">
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-app btn-dark-app">Atualizar</button>
            <a href="/departamentos" class="btn-app btn-outline-app">Cancelar</a>
        </div>
    </form>
</div>

<%- include('../partials/layout-end') %>
